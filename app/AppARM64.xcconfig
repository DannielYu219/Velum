#include "App.xcconfig"
#include "GuestARM64.xcconfig"

// Velum is the ARM64-only product (renamed from iSH ARM64)
PRODUCT_NAME = Velum
PRODUCT_BUNDLE_IDENTIFIER = $(ROOT_BUNDLE_IDENTIFIER)
PRODUCT_APP_GROUP_IDENTIFIER = group.$(ROOT_BUNDLE_IDENTIFIER)

// Velum app version
MARKETING_VERSION = 1.0

// Link meson-built libraries directly from the arm64 meson build dir.
// These are NOT in the Frameworks build phase to prevent Xcode from
// auto-discovering implicit dependencies on the x86 library targets.
OTHER_LDFLAGS = $(inherited) $(MESON_BUILD_DIR)/libish.a $(MESON_BUILD_DIR)/libish_emu.a $(MESON_BUILD_DIR)/libfakefs.a

// Header search paths needed for sources compiled directly in this target
// (previously compiled in libiSHApp, which used AppLib.xcconfig)
HEADER_SEARCH_PATHS = $(inherited) $(SRCROOT) $(SRCROOT)/deps/libarchive/libarchive

// Swift ↔ Obj-C bridging header (Phase 0.2)
SWIFT_OBJC_BRIDGING_HEADER = app/Velum-Bridging-Header.h
SWIFT_VERSION = 5.0

// Dev deployment: use stripped entitlements (no App Groups / Fonts)
// Override the App.xcconfig default which requires explicit App ID provisioning.
CODE_SIGN_ENTITLEMENTS = app/Velum-dev.entitlements
